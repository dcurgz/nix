#!/usr/bin/env bash
GUESTS=(
  'vm-claude'
  'vm-immich'
  'vm-jellyfin'
  'vm-mc-leedl-sta'
  'vm-mc-leedlemon'
  'vm-mc-slime-0'
  'vm-mc-slime-1'
  'vm-mc-wg-0'
  'vm-mc-wg-1'
  'vm-openwebui'
  'vm-teamspeak'
  'vm-trilium'
  'vm-vikunja'
  'vx-jupiter'
)
OUT_DIR="./keys/ssh"

if [ ! -d "$OUT_DIR" ]; then
  echo "$OUT_DIR is not a directory. Are you in the right place?"
  exit 1
fi

for g in "${GUESTS[@]}"; do
  MICROVM_KEYS="/var/lib/microvms/$g/ssh-host-keys"
  mkdir -p "$OUT_DIR/$g"
  cp -v "$MICROVM_KEYS/ssh_host_ed25519_key.pub" "$OUT_DIR/$g/host_ed25519.pub"
done
